rule cnvkit_access:
    output:
        bed = "cnvkit/access_GRCh38.bed"
    log: "cnvkit/access_GRCh38.log"
    singularity: config["containers"]["cnvkit"]
    params:
        fasta = config["fasta"],
        excluded = config["excluded_regions"],
    shell:
        "cnvkit.py access"
        " {params.fasta}"
        " -x <(gunzip -c {params.excluded})"
        " -o {output.bed}"
        " -s 10000" # Merge regions within 10 kbp
        " &> {log}"


rule cnvkit_autobin:
    input:
        crams = [get_cram(sample) for sample in config["samples"]],
        bed = "cnvkit/access_GRCh38.bed"
    output:
        target_bed = "cnvkit/target_GRCh38.bed",
        antitarget_bed = "cnvkit/antitarget_GRCh38.bed"
    log: "cnvkit/autobin_GRCh38.log"
    singularity: config["containers"]["cnvkit"]
    params:
        fasta = config["fasta"],
    shell:
        "cnvkit.py autobin"
        " {input.crams}"
        " -f {params.fasta}"
        " -m wgs"
        " -g {input.bed}"
        # Increase target size max 20kb -> 1Mbp and min 20bp -> 10kbp
        " --target-max-size 1_000_000"
        " --target-min-size 10_000"
        " --bp-per-bin 50000" # Default is 10000, 5000 used in batch.py https://github.com/etal/cnvkit/blob/5cb6aeaf40ea5572063cf9914c456c307b7ddf7a/cnvlib/batch.py#L107C58-L107C65
        " --target-output-bed {output.target_bed}"
        " --antitarget-output-bed {output.antitarget_bed}"
        " &> {log}"


rule target_coverage:
    input:
        bed = "cnvkit/target_GRCh38.bed",
        cram = lambda wc: get_cram(wc.sample)
    output:
        bed = "cnvkit/{sample}/{sample}.regions.bed.gz" 
    singularity: config["containers"]["mosdepth"]
    params:
        ref = config["fasta"],
        prefix = lambda wildcards: f"cnvkit/{wildcards.sample}/{wildcards.sample}"
    threads: 4
    shell:
        "MOSDEPTH_PRECISION=5"
        " mosdepth"
        " --no-per-base"
        " --fast-mode"
        " --fasta {params.ref}"
        " -t {threads}"
        " -b {input.bed}"
        " --mapq 20"
        " {params.prefix}"
        " {input.cram}"
        " &> {params.prefix}.mosdepth.log"


rule bed_to_cnn:
    input:
        bed = "cnvkit/{sample}/{sample}.regions.bed.gz"
    output:
        cnn = "cnvkit/{sample}/{sample}.regions.cnn"
    params:
        header = "chromosome\tstart\tend\tgene\tdepth\tlog2"
    shell:
        "echo '{params.header}' > {output.cnn}"
        " && "
        "zcat {input.bed}"
        " | "
        "awk '{{OFS=\"\\t\"; print $1,$2,$3,\"-\",$5,log($5)/log(2)}}'"
        " | "
        # Replace -inf with -20.0 similar to cnvkit.py coverage command
        # see: https://github.com/etal/cnvkit/blob/5cb6aeaf40ea5572063cf9914c456c307b7ddf7a/cnvlib/coverage.py#L167
        "sed 's|-inf|-20.0|g'"
        " >> {output.cnn}"


rule antitarget_cnn:
    output:
        cnn = "cnvkit/antitarget.cnn"
    params:
        header = "chromosome\tstart\tend\tgene\tdepth\tlog2"
    shell:
        "echo '{params.header}' > {output.cnn}"


rule cnvkit_reference:
    # Create flat reference
    # https://cnvkit.readthedocs.io/en/stable/pipeline.html#with-no-control-samples
    input:
        target_bed = "cnvkit/target_GRCh38.bed",
        antitarget_bed = "cnvkit/antitarget_GRCh38.bed",
    output:
        reference = "cnvkit/reference_GRCh38.cnn"
    log: "cnvkit/reference_GRCh38.log"
    singularity: config["containers"]["cnvkit"]
    params:
        fasta = config["fasta"]
    shell:
        "cnvkit.py reference"
        " -f {params.fasta}"
        " -o {output.reference}"
        " -t {input.target_bed}"
        " -a {input.antitarget_bed}"
        " --no-edge"
        " &> {log}"


rule cnvkit_fix:
    input:
        reference_cnn = "cnvkit/reference_GRCh38.cnn",
        target_cnn = "cnvkit/{sample}/{sample}.regions.cnn",
        antitarget_cnn = "cnvkit/antitarget.cnn"
    output:
        cnr = "cnvkit/{sample}/{sample}.regions.cnr",
    log: "cnvkit/{sample}/{sample}.regions.cnr.log"
    singularity: config["containers"]["cnvkit"]
    shell:
        "cnvkit.py fix"
        " {input.target_cnn}"
        " {input.antitarget_cnn}"
        " {input.reference_cnn}"
        " -o {output.cnr}"
        " --no-edge"
        " &> {log}"


rule cnr_to_bedgraph:
    input:
        cnr = "cnvkit/{sample}/{sample}.regions.cnr"
    output:
        bedgraph = "cnvkit/{sample}/{sample}.regions.log2.bedgraph"
    shell:
        "tail -n +2 {input.cnr}"
        " | "
        "cut -f 1,2,3,5"
        " > {output.bedgraph}"


rule cnvkit_segment:
    input:
        cnr = "cnvkit/{sample}/{sample}.regions.cnr",
    output:
        cns = "cnvkit/{sample}/{sample}.regions.cns",
    log: "cnvkit/{sample}/{sample}.regions.cns.log"
    singularity: config["containers"]["cnvkit"]
    shell:
        "cnvkit.py segment"
        " {input.cnr}"
        " -m hmm-germline"
        " -t 1e-6"
        " -o {output.cns}"
        " &> {log}"


rule cnvkit_segmetrics_ci:
    # https://github.com/etal/cnvkit/blob/5cb6aeaf40ea5572063cf9914c456c307b7ddf7a/cnvlib/batch.py#L279C1-L288C50
    input:
        cns = "cnvkit/{sample}/{sample}.regions.cns",
        cnr = "cnvkit/{sample}/{sample}.regions.cnr"
    output:
        cns = "cnvkit/{sample}/{sample}.regions.segmetrics_ci.cns"
    log: "cnvkit/{sample}/{sample}.regions.segmetrics_ci.cns.log"
    singularity: config["containers"]["cnvkit"]
    shell:
        "cnvkit.py segmetrics"
        " {input.cnr}"
        " -s {input.cns}"
        " -o {output.cns}"
        " --ci"
        " --alpha 0.01" # Default is 0.05 
        # TODO test " --smooth-bootstrap"
        " &> {log}"


rule cnvkit_remove_fp:
    # https://github.com/etal/cnvkit/blob/5cb6aeaf40ea5572063cf9914c456c307b7ddf7a/cnvlib/batch.py#L290-L291
    input:
        cns = "cnvkit/{sample}/{sample}.regions.segmetrics_ci.cns"
    output:
        cns = "cnvkit/{sample}/{sample}.regions.filtered.cns",
    log: "cnvkit/{sample}/{sample}.regions.filtered.cns.log"
    singularity: config["containers"]["cnvkit"]
    params:
        sex = "f"
    shell:
        "cnvkit.py call"
        " {input.cns}"
        " --filter ci"
        " -m none"
        " -x {params.sex}"
        " -o {output.cns}"
        " &> {log}"


rule cnvkit_segmetrics_ttest:
    input:
        cns = "cnvkit/{sample}/{sample}.regions.filtered.cns",
        cnr = "cnvkit/{sample}/{sample}.regions.cnr"
    output:
        cns = "cnvkit/{sample}/{sample}.regions.segmetrics_ttest.cns"
    log: "cnvkit/{sample}/{sample}.regions.segmetrics_ttest.cns.log"
    singularity: config["containers"]["cnvkit"]
    shell:
        "cnvkit.py segmetrics"
        " {input.cnr}"
        " -s {input.cns}"
        " -o {output.cns}"
        " --t-test"
        " &> {log}"


rule cnvkit_call:
    input:
        cns = "cnvkit/{sample}/{sample}.regions.segmetrics_ttest.cns",
    output:
        call = "cnvkit/{sample}/{sample}.regions.call.cns",
    log: "cnvkit/{sample}/{sample}.regions.call.cns.log"
    singularity: config["containers"]["cnvkit"]
    params:
        sex = "f"
    shell:
        "cnvkit.py call"
        " {input.cns}"
        " -m threshold" # TODO - test clonal
        " -o {output.call}"
        " -x {params.sex}"
        " --purity 1.0"
        " &> {log}"


rule cnvkit_call_cnv:
    input:
        cns = "cnvkit/{sample}/{sample}.regions.segmetrics_ttest.cns",
    output:
        call = "cnvkit/{sample}/{sample}.regions.cnv.cns",
    log: "cnvkit/{sample}/{sample}.regions.cnv.cns.log"
    singularity: config["containers"]["cnvkit"]
    params:
        sex = "f"
    shell:
        "cnvkit.py call"
        " {input.cns}"
        " -m clonal"
        " -o {output.call}"
        " -x {params.sex}"
        " --ploidy 2"
        " --purity 1.0"
        " &> {log}"


rule cnvkit_bintest:
    input:
