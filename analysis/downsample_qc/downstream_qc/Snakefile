rule cnvkit_export_vcf:
    input:
        cns = "cnvkit/{sample}/{sample}.regions{ftype}.cns"
    output:
        vcf = "cnvkit/{sample}/{sample}.regions{ftype}.vcf"
    singularity: config["containers"]["cnvkit"]
    params:
        sex = "f"
    shell:
        "cnvkit.py export vcf"
        " {input.cns}"
        " --ploidy 2"
        " -x {params.sex}"
        " -o {output.vcf}"


rule cnvkit_export_seg:
    input:
        cns = expand("cnvkit/{sample}/{sample}.regions{{ftype}}.cns", sample=config["samples"]),
    output:
        seg = "cnvkit/GRCh38{ftype,(|.filtered)}.seg"
    singularity: config["containers"]["cnvkit"]
    shell:
        "cnvkit.py export seg"
        " {input.cns}"
        " -o {output.seg}"
        " && "
        # Remove suffix from sample names
        "sed -i 's|.regions{wildcards.ftype}||g' {output.seg}"


rule export_seg_cnv:
    # CNVkit export seg cannot report copy number values
    input:
        cns = expand("cnvkit/{sample}/{sample}.regions{{ftype}}.cns", sample=config["samples"]),
    output:
        seg = "cnvkit/GRCh38{ftype,(.call|.cnv)}.seg"
    params:
        header = "ID\tchrom\tstart\tend\tcopy_number"
    run:
        with open(output.seg, "w") as f:
            print(params.header, file=f)
            for cns in input.cns:
                sample = cns.split("/")[1]
                with open(cns) as cnsf:
                    # Skip header
                    next(cnsf)

                    for line in cnsf:
                        # chromosome	start	end	gene	log2	cn	depth	p_ttest	probes	weight
                        chromosome, start, end, gene, log2, cn, depth, p_ttest, probes, weight = line.strip().split("\t")
                        print(
                            sample,
                            chromosome,
                            start,
                            end,
                            cn,
                            sep="\t",
                            file=f
                        )

