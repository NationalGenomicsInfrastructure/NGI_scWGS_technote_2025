rule rename_chrs:
    output:
        txt = "chr_replace.txt"
    run:
        with open(output.txt, "w") as f:
            for chrom in list(range(1,23)) + ["X"]:
                print(chrom, f"chr{chrom}", sep=" ", file=f)


def get_vcf(wc):
    prefix = [s for s in samples if s["name"] == wc.sample][0]["prefix"]
    return f"dragena_genotype_vcf/{prefix}.snv.vcf.gz"


rule convert_vcfs:
    input:
        vcf = get_vcf,
        txt = "chr_replace.txt"
    output:
        vcf = "dragena_snvs/{sample}.vcf.gz",
    singularity: config["containers"]["bcftools"]
    shell:
        "bcftools annotate"
        " --rename-chrs {input.txt}"
        " -Oz"
        " -o {output.vcf}"
        " {input.vcf}"

