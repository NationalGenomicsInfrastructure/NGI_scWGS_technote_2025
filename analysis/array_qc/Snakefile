rule regions:
    input:
        vcfs = expand("dragena_snvs/{sample}.vcf.gz", sample=[s["name"] for s in samples])
    output:
        bed = "snvs.bed"
    singularity: config["containers"]["bedtools"]
    params:
        fai = config["fasta"] + ".fai",
        n = lambda wc, input: len(input)
    shell:
        "bedtools multiinter"
        " -i {input.vcfs}"
        " | "
        "awk '$4=={params.n}'"
        # " | "
        # "awk '{{OFS=\"\\t\"; print $1,$2-5,$3+5}}'"
        " > {output.bed}"
        
rule rgt_format:
    output:
        directory("GRCh38.sdf")
    params:
        fasta = config["fasta"],
    singularity: config["containers"]["happy"]
    shell:
        "rtg format -o {output} {params.fasta}"

rule happy:
    input:
        vcf = "dragena_snvs/{sample}.vcf.gz",
        tbi = "dragena_snvs/{sample}.vcf.gz.tbi",
        bed = "snvs.bed",
        sdf = "GRCh38.sdf"
    output:
        csv = "happy/{sample}/{sample}_vspacbio.summary.csv"
    singularity: config["containers"]["happy"]
    log: "happy/{sample}/{sample}_vspacbio.log"
    threads: 1
    params:
        prefix = "happy/{sample}/{sample}_vspacbio",
        ref = "/vulpes/proj/ngis/ngi2016004/private/strategic_proj/SR_23_02_Element_vs_Illumina/resources/GRCh38_GIABv3/unbgzipped/genome.fa", #config["fasta"],
        sdf = config["sdf"],
        truth = config["truth_vcf"],
        pwd = os.getcwd()
    shell:
        "hap.py"
        " --reference {params.ref}"
        " --report-prefix {params.prefix}"
        " --engine-vcfeval-template {params.sdf}"
        " --threads {threads}"
        " --engine=vcfeval"
        " --preprocess-truth"
        " --target-regions {input.bed}"
        " {params.truth}"
        " {params.pwd}/{input.vcf}"
        " &> {log}"
